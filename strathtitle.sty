\usepackage{textpos}
\newcommand{\fromtop}[1]{
  \dimexpr-1in-\topskip-\topmargin-\headheight-\headsep+#1\relax
}
\newcommand{\fromleft}[1]{%
  \dimexpr-1.25in-\oddsidemargin+#1\relax
}

